source "https://rubygems.org"

# Jekyll core
gem "jekyll", "~> 4.4.1"

# Plugins oficiales de Jekyll
gem "jekyll-feed"            # Genera RSS/Atom feed
gem "jekyll-seo-tag"         # SEO automático
gem "jekyll-sitemap"         # Sitemap para motores de búsqueda
gem "jekyll-paginate"        # Paginación (si tu tema lo necesita)
gem "jekyll-paginate-v2"     # Paginación avanzada opcional
gem "jekyll-archives"        # Archivos por categoría, tag, año, etc.

# Para GitHub Pages
gem "github-pages", group: :jekyll_plugins

# Optimización de assets
gem "jekyll-assets"          # Para CSS/JS/imagenes
gem "jekyll-minifier"        # Minifica HTML/CSS/JS

# Temas
gem "minima", "~> 2.5"       # Tema oficial de ejemplo

# Opcionales según necesidades
gem "jekyll-include-cache"    # Cachea includes
gem "jekyll-paginate-v2"      # Mejor paginación
gem "jekyll-redirect-from"    # Redirecciones de páginas
